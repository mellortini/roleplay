{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace=@roleplay/client"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start --workspace=@roleplay/client",
    "restartPolicyMaxRetries": 5
  }
}
