generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characters       Character[]
  gameParticipants GameParticipant[]
  createdSessions  GameSession[]

  @@map("users")
}

model Character {
  id          String @id @default(uuid())
  userId      String
  name        String
  description String @db.Text
  backstory   String @db.Text

  // Avatar
  avatarUrl   String?

  // Stats
  health      Int    @default(100)
  maxHealth   Int    @default(100)
  mana        Int    @default(50)
  maxMana     Int    @default(50)
  strength    Int    @default(10)
  agility     Int    @default(10)
  intelligence Int   @default(10)
  charisma    Int    @default(10)

  // Character details
  level       Int    @default(1)
  experience  Int    @default(0)
  inventory   Json?  @default("[]")
  skills      Json?  @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameParticipants GameParticipant[]
  messages         GameMessage[]

  @@index([userId])
  @@map("characters")
}

model GameSession {
  id          String @id @default(uuid())
  name        String
  description String @db.Text
  creatorId   String

  // Game settings
  gameMode    GameMode  @default(TURN_BASED)
  maxPlayers  Int       @default(4)
  status      GameStatus @default(WAITING)

  // Story/Context
  storyContext String @db.Text @default("")
  currentTurn  Int    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      User              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants GameParticipant[]
  messages     GameMessage[]
  npcs         NPCCharacter[]

  @@index([creatorId])
  @@index([status])
  @@map("game_sessions")
}

model GameParticipant {
  id          String   @id @default(uuid())
  sessionId   String
  userId      String
  characterId String
  joinedAt    DateTime @default(now())
  isActive    Boolean  @default(true)
  turnOrder   Int?

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@unique([sessionId, characterId])
  @@index([sessionId])
  @@index([userId])
  @@map("game_participants")
}

model GameMessage {
  id            String      @id @default(uuid())
  sessionId     String
  characterId   String?
  type          MessageType
  content       String      @db.Text
  action        String?     // For action messages (attack, defend, etc.)
  metadata      Json?       // Additional data (damage dealt, items used, etc.)
  isAiGenerated Boolean     @default(false) // True if message was generated by AI

  createdAt     DateTime    @default(now())

  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character?  @relation(fields: [characterId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
  @@map("game_messages")
}

model NPCCharacter {
  id          String @id @default(uuid())
  sessionId   String
  name        String
  description String @db.Text
  personality String @db.Text
  role        String // enemy, ally, neutral, merchant, etc.

  // Stats
  health      Int    @default(100)
  maxHealth   Int    @default(100)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("npc_characters")
}

// Enums
enum GameMode {
  TURN_BASED
  REAL_TIME
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  PAUSED
  FINISHED
}

enum MessageType {
  CHAT
  ACTION
  NARRATION
  SYSTEM
  NPC_DIALOGUE
  COMBAT
}
